# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=rias-lake

# Postgres (Prefect + optional)
POSTGRES_USER=rias
POSTGRES_PASSWORD=rias
POSTGRES_DB=rias

# Prefect
PREFECT_API_URL=http://localhost:4200/api

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=default
CLICKHOUSE_USER=rias
CLICKHOUSE_PASSWORD=rias

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LMS API (docker internal hostname when running compose)
LMS_API_BASE_URL=http://localhost:8000

# Cube.js (when running cube stack)
CUBEJS_API_SECRET=dev_secret_change_me
CUBEJS_DB_TYPE=clickhouse
CUBEJS_DB_HOST=localhost
CUBEJS_DB_PORT=8123
CUBEJS_DB_USER=rias
CUBEJS_DB_PASS=rias
CUBEJS_DB_NAME=default
